{
  "name": "@hivefetch/core",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./services": "./dist/services/index.js",
    "./*": "./dist/*/index.js"
  },
  "typesVersions": {
