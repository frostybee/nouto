  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "chai": "^4.5.0",
    "jsonpath-plus": "^10.3.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/jest": "^29.5.12",
    "@types/node": "18.x",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  }
}
