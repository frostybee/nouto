---
import Landing from '../layouts/Landing.astro';
import logo from '../assets/sendry-logo.svg';

const features = [
  { title: 'HTTP Requests', desc: 'All methods. Full control over headers, params, body, auth, and cookies.', icon: 'M5 12h14M12 5l7 7-7 7', size: 'normal' },
  { title: 'GraphQL', desc: 'Queries, mutations, and subscriptions with schema explorer and variables.', icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5', size: 'wide' },
  { title: 'WebSocket', desc: 'Real-time bidirectional messaging with connection management.', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', size: 'normal' },
  { title: 'Server-Sent Events', desc: 'Stream events from SSE endpoints in real time.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', size: 'normal' },
  { title: 'Environments & Variables', desc: 'Switch between dev, staging, prod. Use {{variables}} everywhere.', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', size: 'normal' },
  { title: 'Collections & Folders', desc: 'Organize requests with unlimited nesting, folder-level auth and headers, drag-and-drop.', icon: 'M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z', size: 'wide' },
  { title: 'Assertions & Scripts', desc: 'Validate status codes, body, headers, timing. Run pre/post-request JS scripts.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', size: 'normal' },
  { title: 'Mock Server', desc: 'Define local endpoints to test against without a real backend.', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01', size: 'normal' },
  { title: 'Benchmarking', desc: 'Measure endpoint performance with configurable iterations and concurrency.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', size: 'normal' },
  { title: 'Code Generation', desc: 'Generate snippets in JavaScript, Python, cURL, C#, Go, PHP, Ruby, Swift, and more.', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', size: 'normal' },
];

const whyPoints = [
  { label: 'No Telemetry', desc: 'Your data never leaves your machine', icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636' },
  { label: 'No Account', desc: 'No sign-up, no login, no cloud sync', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  { label: '100% Local', desc: 'Everything stored on your filesystem', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: 'Open Source', desc: 'MIT licensed, fully auditable', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
];

const importSources = ['Postman', 'Insomnia', 'Hoppscotch', 'Thunder Client', 'Bruno', 'OpenAPI', 'cURL', 'HAR'];
---

<Landing title="Sendry - Open Source REST Client" description="A fast, privacy-first REST client for VS Code and Desktop. No telemetry, no account, no nonsense.">
  <div class="page">

    <!-- Header -->
    <header class="header">
      <a href="/" class="logo">
        <img src={logo.src} alt="Sendry" width="32" height="32" />
        Sendry
      </a>
      <nav class="nav">
        <a href="/getting-started/installation/" class="nav-link">Docs</a>
        <a href="https://github.com/frostybee/sendry" class="nav-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg class="icon-moon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M17.293 13.293A8 8 0 0 1 6.707 2.707a8.002 8.002 0 1 0 10.586 10.586z"/>
          </svg>
        </button>
      </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-content">
        <div class="hero-badge">Open Source REST Client</div>
        <h1 class="hero-title">
          API testing<br />
          <span class="gradient-text">without the bloat</span>
        </h1>
        <p class="hero-subtitle">
          A fast, privacy-first REST client for VS Code and Desktop.
          No telemetry. No account. No nonsense.
        </p>
        <div class="hero-actions">
          <a href="https://marketplace.visualstudio.com/items?itemName=frostybee.sendry" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M14.5 0L9 5.3V10.7L14.5 16H16V0H14.5ZM0 4.2L3.3 7.1V8.9L0 11.8V4.2ZM5.4 5.6L9 2.5V13.5L5.4 10.4V5.6Z"/></svg>
            Install for VS Code
          </a>
          <a href="/getting-started/installation/" class="btn btn-secondary">
            Get Started
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="screenshot-frame">
          <div class="screenshot-placeholder">
            <div class="placeholder-bar">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            </div>
            <div class="placeholder-body">
              <div class="placeholder-sidebar"></div>
              <div class="placeholder-main">
                <div class="placeholder-urlbar"></div>
                <div class="placeholder-response"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="section-header">
        <span class="section-label">Features</span>
        <h2 class="section-title">Everything you need</h2>
        <p class="section-subtitle">A complete toolkit for API development and testing</p>
      </div>
      <div class="bento-grid">
        {features.map((f) => (
          <article class:list={['bento-card', f.size === 'wide' ? 'wide' : '']}>
            <div class="card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon} />
              </svg>
            </div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Why Sendry -->
    <section class="why">
      <div class="section-header">
        <span class="section-label">Privacy</span>
        <h2 class="section-title">Unlike Postman, Sendry is...</h2>
        <p class="section-subtitle">Built for developers who value privacy and simplicity</p>
      </div>
      <div class="why-grid">
        {whyPoints.map((p) => (
          <div class="why-card">
            <div class="why-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={p.icon} />
              </svg>
            </div>
            <h3>{p.label}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Platforms -->
    <section class="platforms">
      <div class="section-header">
        <span class="section-label">Platforms</span>
        <h2 class="section-title">Two platforms, one experience</h2>
        <p class="section-subtitle">Same UI, same features. Pick what fits your workflow.</p>
      </div>
      <div class="platform-grid">
        <div class="platform-card">
          <div class="platform-icon">
            <svg width="32" height="32" viewBox="0 0 16 16" fill="currentColor">
              <path d="M14.5 0L9 5.3V10.7L14.5 16H16V0H14.5ZM0 4.2L3.3 7.1V8.9L0 11.8V4.2ZM5.4 5.6L9 2.5V13.5L5.4 10.4V5.6Z"/>
            </svg>
          </div>
          <h3>VS Code Extension</h3>
          <p>Works inside your editor. No context switching. Installs in seconds from the Marketplace.</p>
          <a href="https://marketplace.visualstudio.com/items?itemName=frostybee.sendry" class="platform-btn">Install Extension</a>
        </div>
        <div class="platform-card">
          <div class="platform-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <line x1="8" y1="21" x2="16" y2="21" />
              <line x1="12" y1="17" x2="12" y2="21" />
            </svg>
          </div>
          <h3>Desktop App</h3>
          <p>Standalone Tauri 2.0 app. Lightweight, native performance. Windows, macOS, and Linux.</p>
          <a href="https://github.com/frostybee/sendry/releases" class="platform-btn">Download</a>
        </div>
      </div>
    </section>

    <!-- Import -->
    <section class="import">
      <h2>Bring your existing work</h2>
      <p class="import-subtitle">Import collections from the tools you already use</p>
      <div class="import-pills">
        {importSources.map((s) => (
          <span class="pill">{s}</span>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <p>
        <a href="/getting-started/installation/">Docs</a>
        <span class="footer-sep">/</span>
        <a href="https://github.com/frostybee/sendry" target="_blank" rel="noopener noreferrer">GitHub</a>
        <span class="footer-sep">/</span>
        <a href="https://marketplace.visualstudio.com/items?itemName=frostybee.sendry" target="_blank" rel="noopener noreferrer">VS Code Marketplace</a>
      </p>
      <p class="footer-copy">MIT License</p>
    </footer>
  </div>

  <script>
    const toggle = document.getElementById('theme-toggle');
    toggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('starlight-theme', next);
    });
  </script>
</Landing>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ---- Header ---- */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .logo img { width: 32px; height: 32px; }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    position: relative;
    transition: color 0.2s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.3s ease, left 0.3s ease;
  }
  .nav-link:hover { color: var(--color-text); }
  .nav-link:hover::after { width: 100%; left: 0; }

  :global(:root:not([data-theme="dark"])) .nav-link { color: var(--color-text); }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .theme-toggle:hover { color: var(--color-text); border-color: var(--color-text-muted); }

  .icon-moon { display: none; }
  :global([data-theme="dark"]) .icon-sun  { display: none; }
  :global([data-theme="dark"]) .icon-moon { display: block; }

  /* ---- Hero ---- */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 60%;
    background: radial-gradient(ellipse, var(--color-accent-bg) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 42rem;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.5s ease-out 0.05s both;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #a78bfa 40%, #c084fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 auto 2rem;
    max-width: 32rem;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 0.3s both;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border: 1px solid transparent;
    transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }

  .btn-primary {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.25);
  }
  .btn-primary:hover { box-shadow: 0 0 30px rgba(99, 102, 241, 0.4); }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .btn-secondary:hover { border-color: var(--color-text-muted); }

  /* Screenshot placeholder */
  .hero-visual {
    position: relative;
    z-index: 1;
    margin-top: 3rem;
    width: 100%;
    max-width: 56rem;
    animation: fadeInUp 0.7s ease-out 0.4s both;
  }

  .screenshot-frame {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }
  :global([data-theme="dark"]) .screenshot-frame {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 40px rgba(99, 102, 241, 0.06);
  }

  .screenshot-placeholder {
    background: var(--color-bg-alt);
    aspect-ratio: 16 / 10;
  }

  .placeholder-bar {
    display: flex;
    gap: 0.4rem;
    padding: 0.6rem 0.8rem;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-border);
  }

  .placeholder-body {
    display: flex;
    height: calc(100% - 2rem);
    padding: 0.5rem;
    gap: 0.5rem;
  }
  .placeholder-sidebar {
    width: 20%;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
  }
  .placeholder-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .placeholder-urlbar {
    height: 2rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
  }
  .placeholder-response {
    flex: 1;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
  }

  /* ---- Features ---- */
  .features, .why, .platforms, .import {
    padding: 5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header { text-align: center; margin-bottom: 3rem; }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-title { font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; letter-spacing: -0.02em; }
  .section-subtitle { font-size: 1rem; color: var(--color-text-muted); margin-top: 0.5rem; }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .bento-card {
    padding: 1.5rem;
    border-radius: 0.75rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    transition: all 0.25s ease;
    animation: fadeInUp 0.5s ease-out both;
  }
  .bento-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme="dark"]) .bento-card:hover { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25); }

  .bento-card.wide { grid-column: span 2; }

  .bento-card:nth-child(1) { animation-delay: 0.05s; }
  .bento-card:nth-child(2) { animation-delay: 0.1s; }
  .bento-card:nth-child(3) { animation-delay: 0.15s; }
  .bento-card:nth-child(4) { animation-delay: 0.2s; }
  .bento-card:nth-child(5) { animation-delay: 0.25s; }
  .bento-card:nth-child(6) { animation-delay: 0.3s; }
  .bento-card:nth-child(7) { animation-delay: 0.35s; }
  .bento-card:nth-child(8) { animation-delay: 0.4s; }
  .bento-card:nth-child(9) { animation-delay: 0.45s; }
  .bento-card:nth-child(10) { animation-delay: 0.5s; }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 0.5rem;
    background: var(--color-accent-bg);
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .bento-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; }
  .bento-card p { font-size: 0.88rem; line-height: 1.5; color: var(--color-text-muted); }

  /* ---- Why Sendry ---- */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
