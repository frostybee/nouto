---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import Protocols from '../components/Protocols.astro';
import ValueProps from '../components/ValueProps.astro';
import FeatureList from '../components/FeatureList.astro';
import PrivacySection from '../components/PrivacySection.astro';
import PlatformCards from '../components/PlatformCards.astro';
import ImportStrip from '../components/ImportStrip.astro';
import Footer from '../components/Footer.astro';

const protocols = ['HTTP', 'gRPC', 'GraphQL', 'WebSocket', 'SSE'];

const valueProps = [
  {
    icon: '⚡',
    title: 'Fast & Private',
    description: 'No telemetry. No account required. All data stays local on your machine.',
  },
  {
    icon: '📁',
    title: 'Git Friendly',
    description: 'Store collections as plain-text JSON. Version control with Git.',
  },
  {
    icon: '🔧',
    title: 'Extensible',
    description: 'CLI for automation, plugins support, and custom integrations.',
  },
];

const allFeatures = [
  { title: 'HTTP Requests', desc: 'All methods, full header/body/auth control' },
  { title: 'gRPC', desc: 'Unary, server/client streaming, bidirectional with proto support' },
  { title: 'GraphQL', desc: 'Queries, mutations, subscriptions with schema explorer' },
  { title: 'WebSocket', desc: 'Real-time bidirectional messaging with connection management' },
  { title: 'Server-Sent Events', desc: 'Stream events from SSE endpoints in real time' },
  { title: 'Environments', desc: 'Variables, dynamic values, per-environment overrides' },
  { title: 'Collections', desc: 'Nested folders, drag-and-drop, folder-level auth inheritance' },
  { title: 'Assertions', desc: 'Validate status, body, headers, timing with test scripts' },
  { title: 'Mock Server', desc: 'Local endpoints for testing without a backend' },
  { title: 'Benchmarking', desc: 'Measure performance with configurable concurrency' },
  { title: 'Code Generation', desc: 'Snippets in JavaScript, Python, cURL, Go, and more' },
];

const comparison = [
  { feature: 'Telemetry', nouto: 'None', postman: 'Yes', thunder: 'Yes' },
  { feature: 'Account Required', nouto: 'No', postman: 'Yes', thunder: 'No' },
  { feature: 'Local Storage', nouto: 'Yes', postman: 'Cloud-first', thunder: 'Yes' },
  { feature: 'Open Source', nouto: 'MIT', postman: 'No', thunder: 'No' },
  { feature: 'Desktop App', nouto: 'Yes', postman: 'Yes', thunder: 'No' },
  { feature: 'gRPC Support', nouto: 'Yes', postman: 'No', thunder: 'No' },
  { feature: 'GraphQL', nouto: 'Yes', postman: 'Yes', thunder: 'No' },
  { feature: 'WebSocket / SSE', nouto: 'Yes', postman: 'Yes', thunder: 'No' },
];

const importSources = ['Postman', 'Insomnia', 'Hoppscotch', 'Thunder Client', 'Bruno', 'OpenAPI', 'cURL', 'HAR'];
---

<Landing title="Nouto | Open Source REST Client" description="A local-first REST client for VS Code and Desktop. Test HTTP, gRPC, GraphQL, WebSocket, and SSE without creating an account.">
  <div class="page">
    <Hero />
    <Protocols protocols={protocols} />
    <ValueProps features={valueProps} />
    <FeatureList features={allFeatures} />
    <PrivacySection comparison={comparison} />
    <PlatformCards />
    <ImportStrip sources={importSources} />
    <Footer />
  </div>
</Landing>

<style>
  .page {
    min-height: 100vh;
  }
</style>
