---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import FeatureShowcase from '../components/FeatureShowcase.astro';
import FeatureList from '../components/FeatureList.astro';
import PrivacySection from '../components/PrivacySection.astro';
import PlatformCards from '../components/PlatformCards.astro';
import ImportStrip from '../components/ImportStrip.astro';
import Footer from '../components/Footer.astro';
import logo from '../assets/nouto-logo.png';

const showcaseFeatures = [
  {
    title: 'HTTP, gRPC, GraphQL, and more',
    description: 'HTTP, gRPC, GraphQL, WebSocket, SSE. Switch protocols without switching tools. Full control over headers, auth, params, body, and streaming.',
  },
  {
    title: 'Environments and variables',
    description: 'Define variables once, use them everywhere with {{syntax}}. Switch between dev, staging, and production in one click.',
  },
  {
    title: 'Nested collections',
    description: 'Unlimited folder nesting, drag-and-drop, folder-level auth and headers that inherit downward. Import from Postman, Insomnia, or OpenAPI.',
  },
];

const allFeatures = [
  { title: 'HTTP Requests', desc: 'All methods, full header/body/auth control' },
  { title: 'gRPC', desc: 'Unary, server/client streaming, bidirectional with proto support' },
  { title: 'GraphQL', desc: 'Queries, mutations, subscriptions with schema explorer' },
  { title: 'WebSocket', desc: 'Real-time bidirectional messaging with connection management' },
  { title: 'Server-Sent Events', desc: 'Stream events from SSE endpoints in real time' },
  { title: 'Environments', desc: 'Variables, dynamic values, per-environment overrides' },
  { title: 'Collections', desc: 'Nested folders, drag-and-drop, folder-level auth inheritance' },
  { title: 'Assertions', desc: 'Validate status, body, headers, timing with test scripts' },
  { title: 'Mock Server', desc: 'Local endpoints for testing without a backend' },
  { title: 'Benchmarking', desc: 'Measure performance with configurable concurrency' },
  { title: 'Code Generation', desc: 'Snippets in JavaScript, Python, cURL, Go, and more' },
];

const comparison = [
  { feature: 'Telemetry', nouto: 'None', postman: 'Yes', thunder: 'Yes' },
  { feature: 'Account Required', nouto: 'No', postman: 'Yes', thunder: 'No' },
  { feature: 'Local Storage', nouto: 'Yes', postman: 'Cloud-first', thunder: 'Yes' },
  { feature: 'Open Source', nouto: 'MIT', postman: 'No', thunder: 'No' },
  { feature: 'Desktop App', nouto: 'Yes', postman: 'Yes', thunder: 'No' },
  { feature: 'gRPC Support', nouto: 'Yes', postman: 'No', thunder: 'No' },
  { feature: 'GraphQL', nouto: 'Yes', postman: 'Yes', thunder: 'No' },
  { feature: 'WebSocket / SSE', nouto: 'Yes', postman: 'Yes', thunder: 'No' },
];

const importSources = ['Postman', 'Insomnia', 'Hoppscotch', 'Thunder Client', 'Bruno', 'OpenAPI', 'cURL', 'HAR'];
---

<Landing title="Nouto | Open Source REST Client" description="A local-first REST client for VS Code and Desktop. Test HTTP, gRPC, GraphQL, WebSocket, and SSE without creating an account.">
  <div class="page">
    <header class="header">
      <a href="/" class="logo">
        <img src={logo.src} alt="Nouto" width="28" height="28" />
        Nouto
      </a>
      <nav class="nav">
        <a href="/getting-started/installation/" class="nav-link">Docs</a>
        <a href="https://github.com/frostybee/nouto" class="nav-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg class="icon-moon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M17.293 13.293A8 8 0 0 1 6.707 2.707a8.002 8.002 0 1 0 10.586 10.586z"/>
          </svg>
        </button>
      </nav>
    </header>

    <Hero />
    <FeatureShowcase features={showcaseFeatures} />
    <FeatureList features={allFeatures} />
    <PrivacySection comparison={comparison} />
    <PlatformCards />
    <ImportStrip sources={importSources} />
    <Footer />
  </div>

  <script>
    const toggle = document.getElementById('theme-toggle');
    toggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('starlight-theme', next);
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.feature-row, .privacy-inner, .platform-card').forEach(el => {
      el.classList.add('fade-in');
      observer.observe(el);
    });
  </script>
</Landing>

<style>
  .page {
    min-height: 100vh;
  }

  /* Header */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    max-width: 72rem;
    margin: 0 auto;
    border-bottom: 1px solid var(--color-border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  /* Theme toggle */
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.35rem;
    border-radius: 0.35rem;
    color: var(--color-text-muted);
    transition: color 0.15s ease;
    display: flex;
    align-items: center;
  }

  .theme-toggle:hover {
    color: var(--color-text);
  }

  .icon-moon {
    display: none;
  }

  :global([data-theme="dark"]) .icon-sun {
    display: none;
  }

  :global([data-theme="dark"]) .icon-moon {
    display: block;
  }

  @media (max-width: 40rem) {
    .header {
      padding: 0.75rem 1.2rem;
    }
  }
</style>
