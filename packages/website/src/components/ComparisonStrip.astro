---
// "Why Sendry?" comparison strip with key differentiators
const points = [
  { label: 'No Telemetry', desc: 'Your data never leaves your machine', icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636' },
  { label: 'No Account', desc: 'No sign-up, no login, no cloud sync', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  { label: '100% Local', desc: 'Everything stored on your filesystem', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: 'Open Source', desc: 'MIT licensed, fully auditable', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
];
---

<section class="comparison-section">
  <div class="comparison-header">
    <h2 class="section-title">Unlike Postman, Sendry is...</h2>
    <p class="section-subtitle">Built for developers who value privacy and simplicity</p>
  </div>
  <div class="comparison-grid">
    {points.map((p) => (
      <div class="comparison-card">
        <div class="comparison-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d={p.icon} />
          </svg>
        </div>
        <h3 class="comparison-label">{p.label}</h3>
        <p class="comparison-desc">{p.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .comparison-section {
    padding: 4rem 2rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  .comparison-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .comparison-card {
    text-align: center;
    padding: 2rem 1rem;
    border-radius: 0.75rem;
    background: rgba(99, 102, 241, 0.04);
    border: 1px solid rgba(99, 102, 241, 0.1);
    transition: all 0.25s ease;
  }
  .comparison-card:hover {
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.25);
  }

  .comparison-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(99, 102, 241, 0.1);
    color: var(--sl-color-accent);
    margin-bottom: 0.75rem;
  }

  .comparison-label {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.3rem;
  }

  .comparison-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 64rem) {
    .comparison-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 40rem) {
    .comparison-grid {
      grid-template-columns: 1fr;
    }
    .comparison-section {
      padding: 2.5rem 1.2rem;
    }
  }
</style>
