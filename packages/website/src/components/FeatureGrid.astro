---
// Bento-style feature grid with varied card sizes
const features = [
  {
    title: 'HTTP Requests',
    description: 'All methods. Full control over headers, params, body, auth, and cookies.',
    icon: 'M5 12h14M12 5l7 7-7 7',
    size: 'normal',
  },
  {
    title: 'GraphQL',
    description: 'Queries, mutations, and subscriptions with schema explorer and variables.',
    icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
    size: 'wide',
  },
  {
    title: 'WebSocket',
    description: 'Real-time bidirectional messaging with connection management.',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
    size: 'normal',
  },
  {
    title: 'Server-Sent Events',
    description: 'Stream events from SSE endpoints in real time.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    size: 'normal',
  },
  {
    title: 'Environments & Variables',
    description: 'Switch between dev, staging, prod. Use {{variables}} everywhere.',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    size: 'normal',
  },
  {
    title: 'Collections & Folders',
    description: 'Organize requests with unlimited nesting, folder-level auth and headers, drag-and-drop.',
    icon: 'M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z',
    size: 'wide',
  },
  {
    title: 'Assertions & Scripts',
    description: 'Validate status codes, body, headers, timing. Run pre/post-request JS scripts.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    size: 'normal',
  },
  {
    title: 'Mock Server',
    description: 'Define local endpoints to test against without a real backend.',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
    size: 'normal',
  },
  {
    title: 'Benchmarking',
    description: 'Measure endpoint performance with configurable iterations and concurrency.',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
    size: 'normal',
  },
  {
    title: 'Code Generation',
    description: 'Generate snippets in JavaScript, Python, cURL, C#, Go, PHP, Ruby, Swift, and more.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    size: 'normal',
  },
