---
// Import strip showing supported import sources
const sources = [
  'Postman',
  'Insomnia',
  'Hoppscotch',
  'Thunder Client',
  'Bruno',
  'OpenAPI',
  'cURL',
  'HAR',
];
---

<section class="import-section">
  <h2 class="import-title">Bring your existing work</h2>
  <p class="import-subtitle">Import collections from the tools you already use</p>
  <div class="import-pills">
    {sources.map((s) => (
      <span class="import-pill">{s}</span>
    ))}
  </div>
</section>

<style>
  .import-section {
    padding: 3.5rem 2rem;
    max-width: 72rem;
    margin: 0 auto;
    text-align: center;
  }

  .import-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
  }

  .import-subtitle {
    font-size: 1rem;
    color: var(--sl-color-gray-3);
    margin: 0 0 1.5rem;
  }

  .import-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .import-pill {
    display: inline-block;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.2s ease;
  }
  .import-pill:hover {
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.25);
    color: var(--sl-color-accent-high);
  }

  @media (max-width: 40rem) {
    .import-section {
      padding: 2.5rem 1.2rem;
    }
  }
</style>
