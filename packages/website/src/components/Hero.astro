---
import logo from '../assets/nouto-logo.png';
---

<section class="hero">
  <div class="hero-text">
    <h1 class="hero-title">
      Swiss Army knife<br />
      for <span class="gradient-text">API testing</span>
    </h1>
    <p class="hero-sub">
      A local-first REST client for VS Code and Desktop. Test HTTP, gRPC, GraphQL, WebSocket, and SSE without creating an account.
    </p>
    <div class="hero-cta">
      <a href="https://marketplace.visualstudio.com/items?itemName=frostybee-dev.nouto" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M14.5 0L9 5.3V10.7L14.5 16H16V0H14.5ZM0 4.2L3.3 7.1V8.9L0 11.8V4.2ZM5.4 5.6L9 2.5V13.5L5.4 10.4V5.6Z"/></svg>
        Download for VS Code
      </a>
      <a href="/getting-started/installation/" class="btn btn-secondary">Download Desktop App</a>
    </div>
    <div class="hero-stats">
      <span><span class="star">★</span> 1.2k GitHub Stars</span>
      <span>↓ 50k+ Downloads</span>
    </div>
  </div>

  <div class="carousel-section" id="carouselSection">
    <div class="carousel-container">
      <div class="carousel-track" id="carouselTrack">
        <div class="carousel-card far">
          <div class="placeholder">
            <span class="icon">📁</span>
            <span class="label">Collections</span>
          </div>
        </div>
        <div class="carousel-card prev">
          <div class="placeholder">
            <span class="icon">📁</span>
            <span class="label">Collections</span>
          </div>
        </div>
        <div class="carousel-card active">
          <div class="placeholder">
            <span class="icon">⚡</span>
            <span class="label">Request Editor</span>
          </div>
        </div>
        <div class="carousel-card next">
          <div class="placeholder">
            <span class="icon">📊</span>
            <span class="label">Response Viewer</span>
          </div>
        </div>
        <div class="carousel-card far-next">
          <div class="placeholder">
            <span class="icon">📊</span>
            <span class="label">Response Viewer</span>
          </div>
        </div>
      </div>
      <button class="carousel-arrow prev" id="prevBtn" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="carousel-arrow next" id="nextBtn" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
    <div class="carousel-controls">
      <button class="carousel-dot" data-index="0"></button>
      <button class="carousel-dot active" data-index="1"></button>
      <button class="carousel-dot" data-index="2"></button>
      <button class="carousel-dot" data-index="3"></button>
      <button class="carousel-dot" data-index="4"></button>
    </div>
    <p class="fullscreen-hint">Click card or press <kbd>F</kbd> for fullscreen</p>
  </div>
</section>

<!-- Fullscreen Modal -->
<div class="fullscreen-modal" id="fullscreenModal">
  <div class="fullscreen-header">
    <span class="fullscreen-counter" id="fullscreenCounter">3 / 5</span>
    <button class="fullscreen-close" id="fullscreenClose" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="fullscreen-carousel">
    <button class="fullscreen-nav prev" id="fsPrev"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg></button>
    <div class="fullscreen-track" id="fullscreenTrack">
      <div class="fullscreen-card prev"><div class="placeholder"><span class="icon">📁</span><span class="label">Collections</span></div></div>
      <div class="fullscreen-card prev"><div class="placeholder"><span class="icon">📁</span><span class="label">Collections</span></div></div>
      <div class="fullscreen-card active"><div class="placeholder"><span class="icon">⚡</span><span class="label">Request Editor</span></div></div>
      <div class="fullscreen-card next"><div class="placeholder"><span class="icon">📊</span><span class="label">Response Viewer</span></div></div>
      <div class="fullscreen-card next"><div class="placeholder"><span class="icon">📊</span><span class="label">Response Viewer</span></div></div>
    </div>
    <button class="fullscreen-nav next" id="fsNext"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></button>
  </div>
  <div class="fullscreen-footer" id="fullscreenThumbs">
    <button class="fullscreen-thumb" data-index="0">1</button>
    <button class="fullscreen-thumb" data-index="1">2</button>
    <button class="fullscreen-thumb active" data-index="2">3</button>
    <button class="fullscreen-thumb" data-index="3">4</button>
    <button class="fullscreen-thumb" data-index="4">5</button>
  </div>
</div>

<script>
  let currentIndex = 2;
  let autoRotateInterval;
  let isPaused = false;
  
  const track = document.getElementById('carouselTrack');
  const cards = track?.querySelectorAll('.carousel-card');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const carouselSection = document.getElementById('carouselSection');
  
  const fullscreenModal = document.getElementById('fullscreenModal');
  const fullscreenTrack = document.getElementById('fullscreenTrack');
  const fullscreenCards = fullscreenTrack?.querySelectorAll('.fullscreen-card');
  const fullscreenCounter = document.getElementById('fullscreenCounter');
  const fullscreenClose = document.getElementById('fullscreenClose');
  const fullscreenThumbs = document.querySelectorAll('.fullscreen-thumb');
  const fsPrev = document.getElementById('fsPrev');
  const fsNext = document.getElementById('fsNext');
  
  const totalCards = 5;
  
  function updateCarousel() {
    cards?.forEach((card, i) => {
      card.classList.remove('active', 'prev', 'next', 'far', 'far-next');
      const diff = i - currentIndex;
      if (diff === 0) card.classList.add('active');
      else if (diff === -1) card.classList.add('prev');
      else if (diff === 1) card.classList.add('next');
      else if (diff === -2) card.classList.add('far');
      else if (diff === 2) card.classList.add('far-next');
    });
    dots.forEach((dot, i) => dot.classList.toggle('active', i === currentIndex));
  }
  
  function updateFullscreen() {
    fullscreenCards?.forEach((card, i) => {
      card.classList.remove('active', 'prev', 'next');
      const diff = i - currentIndex;
      if (diff === 0) card.classList.add('active');
      else if (diff === -1) card.classList.add('prev');
      else if (diff === 1) card.classList.add('next');
    });
    fullscreenCounter.textContent = `${currentIndex + 1} / ${totalCards}`;
    fullscreenThumbs.forEach((thumb, i) => thumb.classList.toggle('active', i === currentIndex));
  }
  
  function next() { 
    currentIndex = (currentIndex + 1) % totalCards; 
    updateCarousel(); 
    if (fullscreenModal?.classList.contains('active')) updateFullscreen();
  }
  function prev() { 
    currentIndex = (currentIndex - 1 + totalCards) % totalCards; 
    updateCarousel(); 
    if (fullscreenModal?.classList.contains('active')) updateFullscreen();
  }
  function goTo(idx) { 
    currentIndex = idx; 
    updateCarousel(); 
    if (fullscreenModal?.classList.contains('active')) updateFullscreen();
  }
  
  function startAutoRotate() {
    if (autoRotateInterval) clearInterval(autoRotateInterval);
    autoRotateInterval = setInterval(() => {
      if (!isPaused && !fullscreenModal?.classList.contains('active')) {
        next();
      }
    }, 4000);
  }
  
  function pauseAutoRotate() { isPaused = true; }
  function resumeAutoRotate() { isPaused = false; }
  
  function openFullscreen() {
    pauseAutoRotate();
    updateFullscreen();
    fullscreenModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  
  function closeFullscreen() {
    fullscreenModal?.classList.remove('active');
    document.body.style.overflow = '';
    resumeAutoRotate();
  }
  
  // Carousel events
  prevBtn?.addEventListener('click', () => { prev(); startAutoRotate(); });
  nextBtn?.addEventListener('click', () => { next(); startAutoRotate(); });
  dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); startAutoRotate(); }));
  carouselSection?.addEventListener('click', (e) => {
    if (e.target.closest('.carousel-arrow') || e.target.closest('.carousel-dot')) return;
    openFullscreen();
  });
  
  carouselSection?.addEventListener('mouseenter', pauseAutoRotate);
  carouselSection?.addEventListener('mouseleave', resumeAutoRotate);
  
  // Fullscreen events
  fullscreenClose?.addEventListener('click', closeFullscreen);
  fsPrev?.addEventListener('click', prev);
  fsNext?.addEventListener('click', next);
  fullscreenThumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));
  
  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'f' || e.key === 'F') {
      if (!fullscreenModal?.classList.contains('active')) openFullscreen();
    }
    if (fullscreenModal?.classList.contains('active')) {
      if (e.key === 'Escape') closeFullscreen();
      if (e.key === 'ArrowRight') next();
      if (e.key === 'ArrowLeft') prev();
    }
  });
  
  updateCarousel();
  startAutoRotate();
</script>

<style>
  .hero {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
    text-align: center;
  }

  .hero-text {
    margin-bottom: 3rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, #10b981, #34d399, #6ee7b7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.35);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-bg-alt);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .hero-stats span {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .star {
    color: #fbbf24;
  }

  /* Carousel */
  .carousel-section {
    perspective: 1200px;
    overflow: hidden;
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
  }

  .carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel-card {
    position: absolute;
    width: 65%;
    max-width: 600px;
    aspect-ratio: 16/10;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .carousel-card .placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg-alt) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    gap: 0.75rem;
  }

  .carousel-card .placeholder .icon {
    font-size: 2.5rem;
  }

  .carousel-card .placeholder .label {
    font-size: 1rem;
    font-weight: 500;
  }

  .carousel-card.active { transform: translateZ(0) scale(1); z-index: 10; }
  .carousel-card.prev { transform: translateX(-75%) translateZ(-200px) rotateY(25deg); opacity: 0.5; }
  .carousel-card.next { transform: translateX(75%) translateZ(-200px) rotateY(-25deg); opacity: 0.5; }
  .carousel-card.far { transform: translateX(-120%) translateZ(-350px) rotateY(35deg); opacity: 0; }
  .carousel-card.far-next { transform: translateX(120%) translateZ(-350px) rotateY(-35deg); opacity: 0; }

  .fullscreen-hint {
    text-align: center;
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .fullscreen-hint kbd {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: inherit;
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    cursor: pointer;
    transition: all 0.3s;
    border: none;
  }

  .carousel-dot.active {
    background: var(--color-accent);
    width: 28px;
    border-radius: 5px;
  }

  .carousel-dot:hover:not(.active) {
    background: var(--color-text-muted);
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 20;
  }

  .carousel-arrow:hover {
    background: var(--color-bg-alt);
    border-color: var(--color-accent);
  }

  .carousel-arrow.prev { left: 5%; }
  .carousel-arrow.next { right: 5%; }

  /* Fullscreen Modal */
  .fullscreen-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    z-index: 1000;
    display: none;
    flex-direction: column;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .fullscreen-modal.active {
    display: flex;
    opacity: 1;
  }

  .fullscreen-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
  }

  .fullscreen-counter {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .fullscreen-close {
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .fullscreen-close:hover {
    background: var(--color-surface);
  }

  .fullscreen-carousel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1500px;
    position: relative;
  }

  .fullscreen-track {
    position: relative;
    width: 80%;
    max-width: 900px;
    height: 100%;
    max-height: 550px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .fullscreen-card {
    position: absolute;
    width: 100%;
    height: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.5);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fullscreen-card .placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg-alt) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    gap: 1rem;
  }

  .fullscreen-card .placeholder .icon {
    font-size: 4rem;
  }

  .fullscreen-card .placeholder .label {
    font-size: 1.5rem;
    font-weight: 500;
  }

  .fullscreen-card.active { transform: translateZ(0) scale(1); z-index: 10; }
  .fullscreen-card.prev { transform: translateX(-70%) translateZ(-150px) rotateY(20deg); opacity: 0.4; }
  .fullscreen-card.next { transform: translateX(70%) translateZ(-150px) rotateY(-20deg); opacity: 0.4; }

  .fullscreen-footer {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem;
  }

  .fullscreen-thumb {
    width: 80px;
    height: 50px;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    transition: all 0.2s;
  }

  .fullscreen-thumb:hover {
    border-color: var(--color-text-muted);
  }

  .fullscreen-thumb.active {
    border-color: var(--color-accent);
  }

  .fullscreen-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 20;
  }

  .fullscreen-nav:hover {
    background: var(--color-bg-alt);
    border-color: var(--color-accent);
  }

  .fullscreen-nav.prev { left: 3%; }
  .fullscreen-nav.next { right: 3%; }

  @media (max-width: 600px) {
    .hero {
      padding: 2rem 1rem 1rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-stats {
      flex-direction: column;
      gap: 0.5rem;
      align-items: center;
    }

    .carousel-card {
      width: 90%;
    }
  }
</style>
