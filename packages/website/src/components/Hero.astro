---
// Hero: left-aligned text up top, large full-width screenshot below
---

<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-text">
    <h1 class="hero-title">
      API testing<br />
      <span class="gradient-text">without the bloat</span>
    </h1>
    <p class="hero-sub">
      A local-first REST client that lives in VS Code or runs standalone.
      Test HTTP, gRPC, GraphQL, WebSocket, and SSE -- without creating an account.
    </p>
    <div class="hero-cta">
      <a href="https://marketplace.visualstudio.com/items?itemName=frostybee.sendry" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M14.5 0L9 5.3V10.7L14.5 16H16V0H14.5ZM0 4.2L3.3 7.1V8.9L0 11.8V4.2ZM5.4 5.6L9 2.5V13.5L5.4 10.4V5.6Z"/></svg>
        Install for VS Code
      </a>
      <a href="/getting-started/installation/" class="hero-docs-link animated-link">
        Read the docs
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
  <div class="hero-visual">
    <div class="screenshot-frame">
      <div class="screenshot-placeholder">
        <div class="placeholder-shimmer"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 50%;
    background: radial-gradient(ellipse, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  [data-theme="dark"] .hero-glow {
    background: radial-gradient(ellipse, rgba(52, 211, 153, 0.07) 0%, transparent 70%);
  }

  .hero-text {
    position: relative;
    z-index: 1;
    max-width: 36rem;
    margin-bottom: 3.5rem;
  }

  .hero-title {
    font-size: clamp(2.4rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
    color: var(--color-text);
  }

  .gradient-text {
    background: linear-gradient(135deg, #10b981 0%, #34d399 50%, #6ee7b7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.25);
  }

  .btn-primary:hover {
    box-shadow: 0 0 32px rgba(16, 185, 129, 0.4);
    transform: translateY(-1px);
  }

  .hero-docs-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .hero-docs-link:hover {
    color: var(--color-accent);
  }

  /* Large full-width screenshot */
  .hero-visual {
    position: relative;
    z-index: 1;
  }

  .screenshot-frame {
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.12),
      0 0 0 1px rgba(0, 0, 0, 0.04);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .screenshot-frame:hover {
    transform: translateY(-4px);
    box-shadow:
      0 32px 100px rgba(0, 0, 0, 0.16),
      0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  [data-theme="dark"] .screenshot-frame {
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(52, 211, 153, 0.04),
      0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  [data-theme="dark"] .screenshot-frame:hover {
    box-shadow:
      0 32px 100px rgba(0, 0, 0, 0.6),
      0 0 60px rgba(52, 211, 153, 0.06),
      0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .screenshot-placeholder {
    aspect-ratio: 16 / 10;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg-alt) 100%);
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  /* Dot grid pattern */
  .screenshot-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--color-border) 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.5;
  }

  /* Subtle shimmer */
  .placeholder-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 30%,
      rgba(16, 185, 129, 0.04) 50%,
      transparent 70%
    );
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { transform: translateX(-100%); }
    50% { transform: translateX(100%); }
  }

  @media (max-width: 64rem) {
    .hero {
      padding: 3rem 1.5rem 2.5rem;
    }

    .hero-title {
      font-size: clamp(2rem, 6vw, 2.8rem);
    }

    .hero-text {
      margin-bottom: 2.5rem;
    }
  }

  @media (max-width: 40rem) {
    .hero {
      padding: 2rem 1.2rem 2rem;
    }

    .hero-title {
      font-size: 1.8rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
