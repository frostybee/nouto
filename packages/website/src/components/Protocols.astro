---
interface Props {
  protocols: string[];
}

const { protocols } = Astro.props;
---

<section class="protocols">
  <div class="protocols-inner">
    <h2>Call any API</h2>
    <div class="protocol-tags">
      {protocols.map((p) => (
        <span>{p}</span>
      ))}
    </div>
    <p>Full protocol support in one tool. Switch protocols without switching tools.</p>
  </div>
</section>

<style>
  .protocols {
    background: var(--color-surface);
    padding: 4rem 2rem;
  }

  .protocols-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .protocol-tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .protocol-tags span {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
  }

  p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  @media (max-width: 600px) {
    .protocols {
      padding: 3rem 1.2rem;
    }
  }
</style>
