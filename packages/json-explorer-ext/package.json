{
  "name": "nouto-json-explorer",
  "displayName": "Nouto JSON Explorer",
  "description": "A JSON Explorer for VS Code with tree view, table view, fuzzy search, JSONPath filtering, bookmarks, and copy support in multiple formats.",
  "version": "0.1.0",
  "publisher": "frostybee-dev",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/frostybee/nouto"
  },
  "homepage": "https://github.com/frostybee/nouto",
  "bugs": {
    "url": "https://github.com/frostybee/nouto/issues"
  },
  "galleryBanner": {
    "color": "#0c1a24",
    "theme": "dark"
  },
  "icon": "images/icon.png",
  "keywords": [
    "json",
    "json viewer",
    "json explorer",
    "json tree",
    "json table",
    "json query",
    "jsonpath",
    "bookmarks"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:jsonc",
    "onCommand:noutoJsonExplorer.openFile",
    "onCommand:noutoJsonExplorer.openFromDisk",
    "onView:noutoJsonExplorer.sidebar"
  ],
  "main": "./out/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nouto-json-explorer",
          "title": "JSON Explorer",
          "icon": "images/icon-mono.svg"
        }
      ]
    },
    "views": {
      "nouto-json-explorer": [
        {
          "type": "webview",
          "id": "noutoJsonExplorer.sidebar",
          "name": "JSON Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "noutoJsonExplorer.openFile",
        "title": "Open with JSON Explorer",
        "category": "Nouto JSON Explorer",
        "icon": "$(json)"
      },
      {
        "command": "noutoJsonExplorer.openFromDisk",
        "title": "Open JSON File from Disk...",
        "category": "Nouto JSON Explorer",
        "icon": "$(folder-opened)"
      },
      {
        "command": "noutoJsonExplorer.clearRecent",
        "title": "Clear Recent Files",
        "category": "Nouto JSON Explorer",
        "icon": "$(clear-all)"
      },
      {
        "command": "noutoJsonExplorer.showAbout",
        "title": "About",
        "category": "Nouto JSON Explorer",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "noutoJsonExplorer.openFromDisk",
          "when": "view == noutoJsonExplorer.sidebar",
          "group": "navigation"
        },
        {
          "command": "noutoJsonExplorer.clearRecent",
          "when": "view == noutoJsonExplorer.sidebar",
          "group": "navigation"
        },
        {
          "command": "noutoJsonExplorer.showAbout",
          "when": "view == noutoJsonExplorer.sidebar",
          "group": "navigation@3"
        }
      ],
      "explorer/context": [
        {
          "command": "noutoJsonExplorer.openFile",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "noutoJsonExplorer.openFile",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "noutoJsonExplorer.openFile",
          "when": "resourceExtname == .json"
        }
      ],
      "commandPalette": [
        {
          "command": "noutoJsonExplorer.openFile",
          "when": "resourceExtname == .json || editorLangId == json"
        },
        {
          "command": "noutoJsonExplorer.openFromDisk"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "noutoJsonExplorer.view",
        "displayName": "JSON Explorer",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "node esbuild.mjs && pnpm run build:webview",
    "build:webview": "vite build",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production && pnpm run build:webview",
    "typecheck": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.27.3",
    "svelte": "^5.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@nouto/json-explorer": "*",
    "@nouto/core": "*",
    "@vscode/codicons": "^0.0.44"
  }
}
