{
  "name": "@nouto/cli",
  "version": "0.0.1",
  "description": "Nouto CLI - run API collections from the command line",
  "bin": {
    "nouto": "./dist/bin/cli.js"
  },
  "main": "./dist/bin/cli.js",
  "files": [
    "dist/"
  ],
  "scripts": {
