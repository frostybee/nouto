{
  "$schema": "https://v2.tauri.app/reference/config-schema.json",
  "productName": "Nouto",
  "identifier": "com.nouto.app",
  "version": "0.0.1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nouto",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "../../../assets/icons/32x32.png",
      "../../../assets/icons/128x128.png",
      "../../../assets/icons/128x128@2x.png",
      "../../../assets/icons/icon.icns",
      "../../../assets/icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "Copyright © 2026 Nouto Contributors",
    "shortDescription": "The fastest REST API client",
    "longDescription": "Nouto - A blazingly fast REST API client built with Tauri and Rust. 10x faster than Postman with 90% less memory usage.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nouto"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/frostybee/nouto/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
