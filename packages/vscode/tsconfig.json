{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": [
      "ES2020"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "references": [
    { "path": "../core" },
    { "path": "../transport" }
  ],
  "exclude": [
    "node_modules",
    "out",
    "webview-dist",
    "src/test",
    "**/*.test.ts"
  ]
}
