{
  "name": "nouto",
  "displayName": "Nouto",
  "description": "Open-source API client for REST, GraphQL, WebSockets, SSE and gRPC. Runs inside VS Code or as a standalone desktop app.",
  "version": "1.4.0",
  "publisher": "frostybee-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frostybee/nouto"
  },
  "icon": "images/icon.png",
  "homepage": "https://github.com/frostybee/nouto",
  "bugs": {
    "url": "https://github.com/frostybee/nouto/issues"
  },
  "galleryBanner": {
    "color": "#0c1a24",
    "theme": "dark"
  },
  "keywords": [
    "rest client",
    "http client",
    "api client",
    "graphql client",
    "websocket client",
    "sse",
    "grpc client",
    "rest",
    "api",
    "http",
    "graphql",
    "websocket",
    "grpc",
    "postman",
    "testing"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onView:nouto.sidebar",
    "onCommand:nouto.importCurl",
    "onCommand:nouto.newRequest",
    "onCommand:nouto.openInJsonExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nouto.newRequest",
        "title": "New Request",
        "category": "Nouto",
        "icon": "$(add)"
      },
      {
        "command": "nouto.newCollection",
        "title": "New Collection",
        "category": "Nouto",
        "icon": "$(new-folder)"
      },
      {
        "command": "nouto.openRequest",
        "title": "Open Request",
        "category": "Nouto"
      },
      {
        "command": "nouto.openHistoryEntry",
        "title": "Open History Entry",
        "category": "Nouto"
      },
      {
        "command": "nouto.exportHistory",
        "title": "Export History",
        "category": "Nouto",
        "icon": "$(export)"
      },
      {
        "command": "nouto.importHistory",
        "title": "Import History",
        "category": "Nouto",
        "icon": "$(import)"
      },
      {
        "command": "nouto.importPostman",
        "title": "Import Postman Collection",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.importPostmanEnvironment",
        "title": "Import Postman Environment",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.exportPostman",
        "title": "Export to Postman",
        "category": "Nouto",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "nouto.importOpenApi",
        "title": "Import OpenAPI Specification",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.importInsomnia",
        "title": "Import Insomnia Collection",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.importHoppscotch",
        "title": "Import Hoppscotch Collection",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.importCurl",
        "title": "Import from cURL",
        "category": "Nouto",
        "icon": "$(terminal)"
      },
      {
        "command": "nouto.importFromUrl",
        "title": "Import from URL",
        "category": "Nouto",
        "icon": "$(link)"
      },
      {
        "command": "nouto.importThunderClient",
        "title": "Import Thunder Client",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.bulkExport",
        "title": "Bulk Export Collections",
        "category": "Nouto",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "nouto.exportNative",
        "title": "Export as Nouto Format",
        "category": "Nouto",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "nouto.importNative",
        "title": "Import Nouto Collection",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.openMockServer",
        "title": "Open Mock Server",
        "category": "Nouto",
        "icon": "$(server)"
      },
      {
        "command": "nouto.benchmarkRequest",
        "title": "Benchmark Request",
        "category": "Nouto",
        "icon": "$(dashboard)"
      },
      {
        "command": "nouto.openCommandPalette",
        "title": "Search Requests",
        "category": "Nouto",
        "icon": "$(search)"
      },
      {
        "command": "nouto.switchToGlobalStorage",
        "title": "Switch to Global Storage",
        "category": "Nouto"
      },
      {
        "command": "nouto.switchToWorkspaceStorage",
        "title": "Switch to Workspace Storage (.nouto/)",
        "category": "Nouto"
      },
      {
        "command": "nouto.duplicateSelectedRequest",
        "title": "Duplicate Selected Request",
        "category": "Nouto"
      },
      {
        "command": "nouto.openSettings",
        "title": "Settings",
        "category": "Nouto",
        "icon": "$(gear)"
      },
      {
        "command": "nouto.importAuto",
        "title": "Import Collection (Auto-Detect)",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.importHar",
        "title": "Import HAR File",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.exportHar",
        "title": "Export as HAR",
        "category": "Nouto",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "nouto.importBruno",
        "title": "Import Bruno Collection",
        "category": "Nouto",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nouto.exportBackup",
        "title": "Export Backup",
        "category": "Nouto",
        "icon": "$(archive)"
      },
      {
        "command": "nouto.importBackup",
        "title": "Restore from Backup",
        "category": "Nouto",
        "icon": "$(archive)"
      },
      {
        "command": "nouto.openInJsonExplorer",
        "title": "Open in JSON Explorer",
        "category": "Nouto",
        "icon": "$(json)"
      },
      {
        "command": "nouto.openEnvironments",
        "title": "Environments",
        "category": "Nouto",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "nouto.openAbout",
        "title": "About",
        "category": "Nouto",
        "icon": "$(info)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nouto-sidebar",
          "title": "Nouto",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "nouto-sidebar": [
        {
          "type": "webview",
          "id": "nouto.sidebar",
          "name": "Nouto",
          "contextualTitle": "Nouto"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nouto.newRequest",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeViewlet == 'workbench.view.extension.nouto-sidebar'"
      },
      {
        "command": "nouto.importCurl",
        "key": "ctrl+u",
        "mac": "cmd+u"
      },
      {
        "command": "nouto.openCommandPalette",
        "key": "ctrl+k ctrl+k",
        "mac": "cmd+k cmd+k"
      },
      {
        "command": "nouto.duplicateSelectedRequest",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "focusedView == 'nouto.sidebar'"
      },
      {
        "command": "nouto.newCollection",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "activeViewlet == 'workbench.view.extension.nouto-sidebar'"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nouto.openEnvironments",
          "when": "view == nouto.sidebar",
          "group": "1_panels"
        },
        {
          "command": "nouto.openSettings",
          "when": "view == nouto.sidebar",
          "group": "1_panels"
        },
        {
          "command": "nouto.openMockServer",
          "when": "view == nouto.sidebar",
          "group": "1_panels"
        },
        {
          "command": "nouto.importAuto",
          "when": "view == nouto.sidebar",
          "group": "2_import_export"
        },
        {
          "command": "nouto.exportBackup",
          "when": "view == nouto.sidebar",
          "group": "2_import_export"
        },
        {
          "command": "nouto.importBackup",
          "when": "view == nouto.sidebar",
          "group": "2_import_export"
        },
        {
          "command": "nouto.openAbout",
          "when": "view == nouto.sidebar",
          "group": "3_info"
        }
      ],
      "explorer/context": [
        {
          "command": "nouto.openInJsonExplorer",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "nouto.openInJsonExplorer",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "nouto.openInJsonExplorer",
          "when": "resourceExtname == .json || editorLangId == json"
        }
      ]
    },
    "configuration": {
      "title": "Nouto",
      "properties": {
        "nouto.environments": {
          "type": "object",
          "default": {
            "development": {
              "baseUrl": "http://localhost:3000",
              "apiKey": ""
            },
            "production": {
              "baseUrl": "https://api.example.com",
              "apiKey": ""
            }
          },
          "description": "Environment variables for Nouto"
        },
        "nouto.activeEnvironment": {
          "type": "string",
          "default": "development",
          "description": "Currently active environment"
        },
        "nouto.autoCorrectUrls": {
          "type": "boolean",
          "default": false,
          "description": "Automatically correct malformed URLs instead of showing suggestions"
        },
        "nouto.storage.mode": {
          "type": "string",
          "enum": [
            "global",
            "workspace"
          ],
          "default": "global",
          "description": "Storage mode: 'global' stores all collections in VS Code global storage, 'workspace' stores each request as an individual file in .nouto/collections/ for clean git diffs"
        },
        "nouto.shortcuts": {
          "type": "object",
          "default": {},
          "description": "Custom keyboard shortcut overrides for webview actions"
        },
        "nouto.minimap": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "default": "auto",
          "description": "Controls when to show the minimap in response viewers. Auto shows it for large documents (>50 lines), Always shows it always, Never disables it."
        },
        "nouto.ssl.rejectUnauthorized": {
          "type": "boolean",
          "default": true,
          "description": "Global SSL/TLS certificate verification fallback. Set to false to accept self-signed or invalid certificates for all requests (overridden by per-request Settings tab)."
        },
        "nouto.history.saveResponseBody": {
          "type": "boolean",
          "default": true,
          "description": "Save response bodies in request history. Disable to reduce disk usage. Deep search across response bodies requires this to be enabled."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "typecheck": "tsc -p ./ --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "18.x",
    "@types/papaparse": "^5.5.2",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.0",
    "protobufjs": "^7.4.0",
    "@nouto/core": "*",
    "@nouto/transport": "*",
    "form-data": "^4.0.5",
    "httpntlm": "^1.7.7",
    "js-yaml": "^4.1.1",
    "papaparse": "^5.5.3"
  }
}
