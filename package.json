{
  "name": "hivefetch",
  "displayName": "HiveFetch",
  "description": "A 100% open-source, privacy-respecting REST client for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:hivefetch.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hivefetch.newRequest",
        "title": "New Request",
        "category": "HiveFetch",
        "icon": "$(add)"
      },
      {
        "command": "hivefetch.newCollection",
        "title": "New Collection",
        "category": "HiveFetch",
        "icon": "$(new-folder)"
      },
      {
        "command": "hivefetch.openRequest",
        "title": "Open Request",
        "category": "HiveFetch"
      },
      {
        "command": "hivefetch.openHistoryEntry",
        "title": "Open History Entry",
        "category": "HiveFetch"
      },
      {
        "command": "hivefetch.importPostman",
        "title": "Import Postman Collection",
        "category": "HiveFetch",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hivefetch.exportPostman",
        "title": "Export to Postman",
        "category": "HiveFetch",
        "icon": "$(cloud-upload)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hivefetch-sidebar",
          "title": "HiveFetch",
          "icon": "$(globe)"
        }
      ]
    },
    "views": {
      "hivefetch-sidebar": [
        {
          "type": "webview",
          "id": "hivefetch.sidebar",
          "name": "HiveFetch",
          "contextualTitle": "HiveFetch"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hivefetch.newRequest",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeViewlet == 'workbench.view.extension.hivefetch-sidebar'"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hivefetch.newRequest",
          "when": "view == hivefetch.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "hivefetch.newCollection",
          "when": "view == hivefetch.sidebar",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "HiveFetch",
      "properties": {
        "hivefetch.environments": {
          "type": "object",
          "default": {
            "development": {
              "baseUrl": "http://localhost:3000",
              "apiKey": ""
            },
            "production": {
              "baseUrl": "https://api.example.com",
              "apiKey": ""
            }
          },
          "description": "Environment variables for HiveFetch"
        },
        "hivefetch.activeEnvironment": {
          "type": "string",
          "default": "development",
          "description": "Currently active environment"
        },
        "hivefetch.autoCorrectUrls": {
          "type": "boolean",
          "default": false,
          "description": "Automatically correct malformed URLs instead of showing suggestions"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "tsc -p ./",
    "compile:webview": "cd src/webview && npm run build",
    "watch": "npm run watch:extension",
    "watch:extension": "tsc -watch -p ./",
    "watch:webview": "cd src/webview && npm run dev",
    "install:all": "npm install && cd src/webview && npm install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "pretest:integration": "npm run compile && npm run compile:integration",
    "test:integration": "node out/test/runTest.js",
    "test:all": "npm run test:coverage && cd src/webview && npm run test:coverage && npm run test:integration"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^10.5.0",
    "jest": "^29.7.0",
    "mocha": "^10.8.2",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "form-data": "^4.0.5"
  }
}
