{
  "name": "vsc-restease",
  "displayName": "VSC-RestEase",
  "description": "A powerful REST client for Visual Studio Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:restease.newRequest"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "restease.newRequest",
        "title": "New Request",
        "category": "RestEase"
      }
    ],
    "views": {
      "restease": [
        {
          "id": "restease.collections",
          "name": "Collections",
          "when": "true"
        },
        {
          "id": "restease.history",
          "name": "History",
          "when": "true"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "restease",
          "title": "RestEase",
          "icon": "$(globe)"
        }
      ]
    },
    "configuration": {
      "title": "RestEase",
      "properties": {
        "restease.environments": {
          "type": "object",
          "default": {
            "development": {
              "baseUrl": "http://localhost:3000",
              "apiKey": ""
            },
            "production": {
              "baseUrl": "https://api.example.com",
              "apiKey": ""
            }
          },
          "description": "Environment variables for RestEase"
        },
        "restease.activeEnvironment": {
          "type": "string",
          "default": "development",
          "description": "Currently active environment"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
} 