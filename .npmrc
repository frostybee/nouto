# pnpm configuration
# See: https://pnpm.io/npmrc

# Use strict peer dependencies (catch version conflicts early)
strict-peer-dependencies=false

# Faster installations with symlinks
symlink=true

# Auto-install peers (helpful for development)
auto-install-peers=true

# Shamefully hoist packages that need to be hoisted (fixes some compatibility issues)
shamefully-hoist=false

# Public hoist pattern (for packages that need to be accessible to all)
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*

# Use workspace protocol for local packages
link-workspace-packages=true

# Save exact versions (more predictable builds)
save-exact=false
